def crearTareaLimpieza(celula):
    # Tareas.Data.Independiente.crearTareaLimpieza(celula)
    """
    Script que programa automáticamente una tarea de limpieza para la célula indicada.
    Usa la query avanzada con INNER JOIN para determinar la última limpieza real.
    """
    from system.dataset import toDataSet
    
    #---PARAMETROS ORIGINALES----------------------------------
    tp = constantes.tag_provider
    celulaLinea = constantes.celulaLinea
    tagPath = tp + "Dataset/Tareas_Celula" + celulaLinea
    #----------------------------------------------------------
    
    try:
        # 1. Leer dataset actual de tareas para el candado y candidatos
        dataset = system.tag.readBlocking([tagPath])[0].value
        if dataset is None:
            return "Error: No se pudo leer el dataset del tag."
            
        columnas = list(dataset.getColumnNames())
        
        # --- [NUEVO] PASO 1.5: CANDADO DE EXISTENCIA ---
        celula_buscada = str(celula).strip().upper()
        for i in range(dataset.getRowCount()):
            t_nom = str(dataset.getValueAt(i, "tarea")).strip().upper()
            t_cel = str(dataset.getValueAt(i, "celula")).strip().upper()
            t_est = dataset.getValueAt(i, "completado")
            
            if "LIMPIEZA" in t_nom and t_cel == celula_buscada and t_est == 0:
                print "CANDADO: Ya existe Limpieza pendiente para %s. Abortando." % celula
                return True 
        # -----------------------------------------------

        # 2. Obtener última limpieza completada (QUERY ACTUALIZADA)
        # Esta es la query que me has pasado con el JOIN y filtros específicos
        query = """
            SELECT TOP 1 C.fecha 
            FROM G_Pilot_Completados C
            INNER JOIN G_Pilot_Tareas_Resumen T ON C.idTareasR = T.id
            WHERE T.tarea LIKE 'Limpieza%' 
              AND T.celula = ? 
              AND T.activo = 1 
              AND C.InicioFin = 1
            ORDER BY C.fecha DESC
        """
        try:
            # Usamos runScalarPrepQuery para mayor seguridad con el parámetro [celula]
            ultima_limpieza = system.db.runScalarPrepQuery(query, [celula])
        except:
            ultima_limpieza = None
            
        if ultima_limpieza is None:
            # Si no hay registros, usamos una fecha muy antigua (20 años atrás)
            ultima_limpieza = system.date.addYears(system.date.now(), -20)

        # 3. Determinar hora actual y turno (Manteniendo tu lógica original)
        ahora = system.date.now()
        hora_actual = system.date.getHour24(ahora)
        
        if 6 <= hora_actual < 14:
            inicio_turno = system.date.midnight(ahora)
            inicio_turno = system.date.addHours(inicio_turno, 6)
            fin_turno = system.date.addHours(inicio_turno, 8)
        elif 14 <= hora_actual < 22:
            inicio_turno = system.date.midnight(ahora)
            inicio_turno = system.date.addHours(inicio_turno, 14)
            fin_turno = system.date.addHours(inicio_turno, 8)
        else:
            inicio_turno = system.date.midnight(ahora)
            if hora_actual < 6:
                inicio_turno = system.date.addDays(inicio_turno, -1)
                inicio_turno = system.date.addHours(inicio_turno, 22)
            else:
                inicio_turno = system.date.addHours(inicio_turno, 22)
            fin_turno = system.date.addHours(inicio_turno, 8)
        
        # 4. Buscar candidatos filtrando por celula
        candidatos = []
        for i in range(dataset.getRowCount()):
            row = {col: dataset.getValueAt(i, col) for col in columnas}
            
            if row["completado"] == 0 and str(row["celula"]).strip() == str(celula).strip():
                t_up = str(row["tarea"]).upper()
                m_up = str(row["maquina"]).upper()
                if t_up.startswith("CH") and m_up == "TALLADORA":
                    candidatos.append((row, 1))
                elif t_up.startswith("CH") and m_up == "AFEITADORA":
                    candidatos.append((row, 2))
                elif "GRAFICO" in t_up:
                    candidatos.append((row, 3))
        
        candidatos.sort(key=lambda x: (x[1], x[0]["cuando"]))
        
        # 5. Validar candidatos (Regla 4 horas)
        tarea_limpieza = None
        for row, prioridad in candidatos:
            diff_horas = system.date.hoursBetween(ultima_limpieza, row["cuando"])
            if diff_horas >= 4:
                tarea_limpieza = row
                break
        
        # 6. Definir datos de la nueva tarea
        if not tarea_limpieza:
            fecha_final = system.date.addHours(fin_turno, -2)
        else:
            fecha_final = tarea_limpieza["cuando"]

        dict_final = {
            "tarea": "Limpieza",
            "cuando": fecha_final,
            "celula": celula,
            "maquina": "GENERAL",
            "elemento": "Limpieza del puesto",
            "ocurrencia": 0,
            "completado": 0
        }
        
        # 7. Insertar en dataset
        nuevas_filas = [ [dataset.getValueAt(i, col) for col in columnas] for i in range(dataset.getRowCount()) ]
        nuevas_filas.append([dict_final.get(col, None) for col in columnas])
        
        dataset_actualizado = toDataSet(columnas, nuevas_filas)
        system.tag.writeBlocking([tagPath], [dataset_actualizado])
        
        print("✅ Tarea creada con éxito para: " + str(fecha_final))
        return True
    
    except Exception as e:
        return("Error en crearTareaLimpieza(): " + str(e))
    

